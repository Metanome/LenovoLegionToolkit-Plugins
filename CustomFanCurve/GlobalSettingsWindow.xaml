<wpfui:UiWindow x:Class="LenovoLegionToolkit.Plugin.CustomFanCurve.GlobalSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:LenovoLegionToolkit.Plugin.CustomFanCurve"
        Title="{x:Static local:Strings.SettingsWindowTitle}"
        Width="780" Height="580" MinWidth="700" MinHeight="480"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Width" Value="120"/><Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/><Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="SubHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,24,0,12"/>
        </Style>
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,12"/><Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="NavListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid Margin="0,1">
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="4" Padding="12,10">
                                <ContentPresenter/>
                            </Border>
                            <Rectangle x:Name="Active" Width="3" Height="16" HorizontalAlignment="Left" VerticalAlignment="Center" RadiusX="2" RadiusY="2" Visibility="Collapsed">
                                <Rectangle.Fill><SolidColorBrush Color="{DynamicResource SystemAccentColorSecondary}"/></Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                <Setter TargetName="Active" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Grid.ColumnDefinitions><ColumnDefinition Width="230"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="24,20,24,20"
                       FontSize="22" FontWeight="Medium" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Text="{x:Static local:Strings.SettingsTitle}"/>

            <Border Grid.Row="1" Grid.Column="0" Background="Transparent" BorderThickness="0" Margin="24,0,8,0">
                <ListBox x:Name="_navListBox" Background="Transparent" BorderThickness="0" SelectionChanged="NavListBox_SelectionChanged">
                    <ListBoxItem Style="{StaticResource NavListBoxItem}" Tag="0" IsSelected="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔌" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{x:Static local:Strings.Basic}" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavListBoxItem}" Tag="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📡" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{x:Static local:Strings.SensorAndCalc}" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavListBoxItem}" Tag="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚀" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{x:Static local:Strings.SpinUpBoost}" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavListBoxItem}" Tag="3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{x:Static local:Strings.ModeSwitch}" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavListBoxItem}" Tag="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔧" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{x:Static local:Strings.Advanced}" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </Border>

            <ContentControl x:Name="_contentHost" Grid.Row="1" Grid.Column="1" Margin="16,0,24,0" Focusable="False">
                <ScrollViewer x:Name="_contentScroll" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <StackPanel>
                        <!-- Panel 0: Basic -->
                        <StackPanel x:Name="_panelBasic" Visibility="Visible">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static local:Strings.Basic}"/>
                            <Border Style="{StaticResource InfoCard}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.EnableCurve}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.EnableCurveDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding IsCustomFanEnabled}"/>
                                    </Grid>
                                    <Separator Opacity="0.3" Margin="0,0,0,14"/>
                                    <Grid Margin="0,0,0,14" Visibility="{Binding IsLegionDevice, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.ApplyToAllModes}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.ApplyToAllModesDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding ApplyToAllPowerModes}"/>
                                    </Grid>
                                    <Separator Opacity="0.3" Margin="0,0,0,14" Visibility="{Binding IsLegionDevice, Converter={StaticResource BoolToVis}}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.DebugMode}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.DebugModeDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding DebugMode}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Panel 1: Sensor & Calc -->
                        <StackPanel x:Name="_panelSensor" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static local:Strings.SensorPolling}"/>
                            <Border Style="{StaticResource InfoCard}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.SensorInterval}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.SensorIntervalDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBox Grid.Column="1" Style="{StaticResource SettingsTextBox}" Text="{Binding SensorIntervalMs, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                    <Separator Opacity="0.3" Margin="0,0,0,14"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.IgnoreZeroTemp}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.IgnoreZeroTempDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding IgnoreZeroTemperature}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <TextBlock Style="{StaticResource SubHeader}" Text="{x:Static local:Strings.CalcScheduling}"/>
                            <Border Style="{StaticResource InfoCard}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.CalcInterval}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.CalcIntervalDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBox Grid.Column="1" Style="{StaticResource SettingsTextBox}" Text="{Binding CalculationDelayMs, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                    <Separator Opacity="0.3" Margin="0,0,0,14"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.TempDeltaThreshold}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.TempDeltaThresholdDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBox Grid.Column="1" Style="{StaticResource SettingsTextBox}" Text="{Binding TemperatureDeltaThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Panel 2: Spin-Up Boost -->
                        <StackPanel x:Name="_panelSpinUp" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static local:Strings.SpinUpBoost}"/>
                            <Border Style="{StaticResource InfoCard}">
                                <TextBlock Text="{x:Static local:Strings.SpinUpDesc}" FontSize="12" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" LineHeight="20"/>
                            </Border>
                            <Border Style="{StaticResource InfoCard}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.EnableSpinUp}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding SpinUpBoostEnabled}"/>
                                    </Grid>
                                    <Separator Opacity="0.3" Margin="0,0,0,14"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.SpinUpRpm}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.SpinUpRpmDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBox Grid.Column="1" Style="{StaticResource SettingsTextBox}" Text="{Binding SpinUpBoostRpm, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                    <Separator Opacity="0.3" Margin="0,0,0,14"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.SpinUpDuration}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.SpinUpDurationDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBox Grid.Column="1" Style="{StaticResource SettingsTextBox}" Text="{Binding SpinUpBoostDurationMs, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Panel 3: Mode Switch -->
                        <StackPanel x:Name="_panelModeSwitch" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static local:Strings.ModeSwitchTitle}"/>
                            <Border Style="{StaticResource InfoCard}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.ForceRefreshOnSwitch}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.ForceRefreshOnSwitchDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding ForceRefreshOnModeSwitch}"/>
                                    </Grid>
                                    <Separator Opacity="0.3" Margin="0,0,0,14"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.RefreshCount}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.RefreshCountDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBox Grid.Column="1" Style="{StaticResource SettingsTextBox}" Text="{Binding ModeSwitchRefreshCount, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                    <Separator Opacity="0.3" Margin="0,0,0,14"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.RefreshInterval}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.RefreshIntervalDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBox Grid.Column="1" Style="{StaticResource SettingsTextBox}" Text="{Binding ModeSwitchRefreshDelayMs, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                    <Separator Opacity="0.3" Margin="0,0,0,14"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.ForceRefreshOnEnable}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding ForceRefreshOnEnable}"/>
                                    </Grid>
                                    <Separator Opacity="0.3" Margin="0,0,0,14"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.ClearCacheOnLeave}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.ClearCacheOnLeaveDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding ClearCachedStateWhenLeavingCustomMode}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Panel 4: Advanced -->
                        <StackPanel x:Name="_panelAdvanced" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static local:Strings.UiAndMonitoring}"/>
                            <Border Style="{StaticResource InfoCard}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.UiUpdateInterval}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.UiUpdateIntervalDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBox Grid.Column="1" Style="{StaticResource SettingsTextBox}" Text="{Binding UiUpdateIntervalMs, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                    <Separator Opacity="0.3" Margin="0,0,0,14"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.UseCachedSnapshot}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.UseCachedSnapshotDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding UseCachedSnapshotForForcedRefresh}"/>
                                    </Grid>
                                    <Separator Opacity="0.3" Margin="0,0,0,14"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Static local:Strings.WriteEachCycle}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Static local:Strings.WriteEachCycleDesc}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding EnableMaxFanWriteEachCycle}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </ContentControl>
        </Grid>

        <Border Grid.Row="1" Padding="24,16" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{x:Static local:Strings.SaveHint}"/>
                <Button Grid.Column="1" MinWidth="120" Height="36" Click="Save_Click" FontSize="13" FontWeight="SemiBold" Cursor="Hand" IsDefault="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource AccentButtonBackground}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentButtonForeground}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonBackground}"/>
                            <Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="24,6"/>
                            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger></Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" Margin="0,0,6,0" FontSize="14"/>
                        <TextBlock Text="{x:Static local:Strings.Save}"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" MinWidth="100" Height="36" Margin="12,0,0,0" Click="Cancel_Click" FontSize="13" Cursor="Hand" IsCancel="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="24,6"/>
                            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/></Trigger></Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✕" Margin="0,0,6,0" FontSize="14"/>
                        <TextBlock Text="{x:Static local:Strings.Cancel}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</wpfui:UiWindow>
