<Page x:Class="LenovoLegionToolkit.Plugin.CustomFanCurve.CustomFanCurvePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LenovoLegionToolkit.Plugin.CustomFanCurve"
      xmlns:res="clr-namespace:LenovoLegionToolkit.Plugin.CustomFanCurve.Resources"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="{x:Static res:Resource.WindowTitle}"
      Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
    <Page.Resources>
        <Style x:Key="ToolBarButton" TargetType="Button">
            <Setter Property="Height" Value="36"/><Setter Property="MinWidth" Value="110"/>
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="14,5"/>
            <Setter Property="FontSize" Value="13"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/><Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ToolBarAccentButton" TargetType="Button" BasedOn="{StaticResource ToolBarButton}">
            <Setter Property="Background" Value="{DynamicResource AccentButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentButtonForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonBackground}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16,12" Margin="0,0,0,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="_enableCustomFanToggle" Grid.Column="0" VerticalAlignment="Center"
                          Checked="EnableCustomFan_Changed" Unchecked="EnableCustomFan_Changed"
                          FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                    <TextBlock Text="{x:Static res:Resource.EnableCustomFanCurve}"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </CheckBox>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border Padding="6,0" CornerRadius="6" Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="_fanSelector" Width="100" VerticalAlignment="Center"
                                      SelectionChanged="FanSelector_SelectionChanged" Background="Transparent"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderThickness="0"
                                      Padding="6,4" FontSize="13"/>
                            <Separator Style="{x:Null}" Width="1" Margin="4,6"
                                       Background="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                            <Button x:Name="_addNodeButton" Height="32" MinWidth="36" VerticalAlignment="Center"
                                    Click="AddNode_Click" Background="Transparent"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderThickness="0"
                                    FontSize="18" FontWeight="Bold" Cursor="Hand"
                                    ToolTip="{x:Static res:Resource.AddNodeTooltip}" Padding="8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ui:SymbolIcon Symbol="Add24" />
                            </Button>
                        </StackPanel>
                    </Border>
                    <Border Width="1" Margin="14,6" VerticalAlignment="Stretch"
                            Background="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                    <Button x:Name="_maxFanButton" Style="{StaticResource ToolBarButton}" MinWidth="140"
                            Click="MaxFan_Click" ToolTip="{x:Static res:Resource.MaxSpeedTooltip}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Flash24" Margin="0,0,6,0" FontSize="15" />
                            <TextBlock Text="{x:Static res:Resource.MaxSpeed}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="_globalSettingsButton" Style="{StaticResource ToolBarAccentButton}"
                            Margin="10,0,0,0" Click="GlobalSettings_Click"
                            ToolTip="{x:Static res:Resource.GlobalSettingsTooltip}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" Margin="0,0,6,0" FontSize="15" />
                            <TextBlock Text="{x:Static res:Resource.GlobalSettings}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="_loadingOverlay" Grid.Row="1" Visibility="Collapsed"
              Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
            <ui:ProgressRing Width="40" Height="40" IsIndeterminate="True"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <StackPanel x:Name="_fanControlStackPanel" Grid.Row="1" Visibility="Collapsed"/>

        <Grid x:Name="_smartAutoDashboard" Grid.Row="1" Visibility="Collapsed" Margin="0,20,0,0">
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="24">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:SymbolIcon x:Name="_dashboardIcon" Symbol="BrainCircuit24" FontSize="48" Margin="0,0,0,16" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                    <TextBlock x:Name="_dashboardTitle" Text="{x:Static res:Resource.SmartAutoDashboardTitle}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="{x:Static res:Resource.SmartAutoDashboardSubtitle}" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="500" Margin="0,0,0,32"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="16"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="12"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/><RowDefinition Height="Auto"/><RowDefinition Height="12"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Resource.SmartAutoThermalState}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="_dashboardThermalState" Grid.Row="0" Grid.Column="2" Text="-" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static res:Resource.SmartAutoPowerLoad}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="_dashboardPowerLoad" Grid.Row="2" Grid.Column="2" Text="-" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static res:Resource.SmartAutoDecision}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="_dashboardDecision" Grid.Row="4" Grid.Column="2" Text="-" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="{x:Static res:Resource.SmartAutoTargetOutput}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="_dashboardOutput" Grid.Row="6" Grid.Column="2" Text="-" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
