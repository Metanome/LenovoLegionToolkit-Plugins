<UserControl
    x:Class="LenovoLegionToolkit.Plugin.CustomFanCurve.CustomFanCurveControlV3"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:LenovoLegionToolkit.Plugin.CustomFanCurve"
    FlowDirection="LeftToRight">
    <UserControl.Resources>
        <Style x:Key="NodeTextBox" TargetType="TextBox">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style x:Key="NodeTextBoxRTL" TargetType="TextBox" BasedOn="{StaticResource NodeTextBox}">
            <Setter Property="FlowDirection" Value="LeftToRight"/>
        </Style>
        <Style x:Key="SidePanelTextBox" TargetType="TextBox" BasedOn="{StaticResource NodeTextBoxRTL}">
            <Setter Property="Width" Value="72"/>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Padding="0,0,8,0" Background="Transparent">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="11" FontWeight="Medium"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="100%"/>
                <TextBlock Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="11" FontWeight="Medium"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="80%"/>
                <TextBlock Grid.Row="4" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="11" FontWeight="Medium"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="60%"/>
                <TextBlock Grid.Row="6" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="11" FontWeight="Medium"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="40%"/>
                <TextBlock Grid.Row="8" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="11" FontWeight="Medium"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="20%"/>
                <TextBlock Grid.Row="10" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Text="{x:Static local:Strings.FanSpeed}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="0" Grid.Column="1" MinHeight="240">
            <Grid.RowDefinitions><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Grid.Row="0" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,1" Margin="4,0,4,0"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8,0,0,0"/>
            <ScrollViewer x:Name="_scrollViewer" Grid.Row="0" Focusable="False"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          ScrollChanged="ScrollViewer_ScrollChanged" Background="Transparent">
                <Grid>
                    <Grid Margin="0,40,0,88" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Canvas x:Name="_canvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="True"/>
                    </Grid>
                    <ItemsControl x:Name="_nodeItemsControl" ItemsSource="{Binding CurveNodes}" Margin="0,40,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid MinWidth="76" Margin="10,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="26"/>
                                        <RowDefinition Height="*" MinHeight="240"/>
                                        <RowDefinition Height="34"/>
                                        <RowDefinition Height="34"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0" Width="20" Height="20" Margin="0,0,0,4"
                                            HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                            Command="{Binding DataContext.RemovePointCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" Cursor="Hand" FontSize="11"
                                            ToolTip="{x:Static local:Strings.DeleteNode}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <Setter Property="Content" Value="✕"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#E81123"/>
                                                        <Setter Property="Background" Value="#20E81123"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Slider Grid.Row="1" Width="40" Margin="0,4"
                                            HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                            Orientation="Vertical" IsSnapToTickEnabled="True" IsMoveToPointEnabled="False"
                                            Minimum="0" Maximum="100" TickFrequency="1" Value="{Binding TargetPercent}">
                                        <Slider.Style><Style TargetType="Slider"><Setter Property="Background" Value="Transparent"/></Style></Slider.Style>
                                    </Slider>
                                    <TextBox Grid.Row="2" Style="{StaticResource NodeTextBoxRTL}" Margin="0,4,0,0"
                                             DataObject.Pasting="NumericTextBox_Pasting"
                                             PreviewTextInput="NumericTextBox_PreviewTextInput"
                                             Text="{Binding TargetPercent}"
                                             ToolTip="{x:Static local:Strings.TargetPercent}"/>
                                    <TextBox Grid.Row="3" Style="{StaticResource NodeTextBoxRTL}" Margin="0,2,0,0"
                                             DataObject.Pasting="NumericTextBox_Pasting"
                                             PreviewTextInput="TemperatureTextBox_PreviewTextInput"
                                             Text="{Binding Temperature, StringFormat=N0}"
                                             ToolTip="{x:Static local:Strings.TemperatureUnit}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="0" Grid.Column="2" Width="256" Margin="12,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="14,12"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="{x:Static local:Strings.LiveMonitor}"/>
                    <Separator Margin="0,0,0,8" Opacity="0.3"/>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{x:Static local:Strings.Temperature}"/>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="{Binding DisplayTemp}"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{x:Static local:Strings.CurrentSpeed}"/>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" Text="{Binding ActualRpmDisplay}"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{x:Static local:Strings.TargetSpeed}"/>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="{Binding TargetRpmDisplay}"/>
                    </Grid>
                    <ProgressBar Height="4" Margin="0,8,0,0" Maximum="6400"
                                 Value="{Binding CurrentRpmValue}"
                                 Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                 Background="{DynamicResource ControlFillColorDefaultBrush}" BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="1" Margin="4,6,4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="100 °C"/>
        </Grid>
    </Grid>
</UserControl>
